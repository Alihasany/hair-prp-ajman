---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home - Expert Hair PRP Treatment in Ajman">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-emerald-50 to-amber-50 py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl md:text-6xl font-serif font-bold text-gray-900 mb-6 leading-tight">
          Restore Your Hair,<br/>
          <span class="text-emerald-600">Regain Your Confidence</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 mb-8 leading-relaxed">
          Advanced Hair PRP (Platelet-Rich Plasma) treatment in Ajman, UAE.
          A natural, non-surgical solution for hair loss that uses your body's own healing power.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="bg-emerald-600 text-white px-8 py-4 rounded-full font-semibold hover:bg-emerald-700 transition shadow-lg text-center">
            Book Free Consultation
          </a>
          <a href="/services" class="border-2 border-emerald-600 text-emerald-600 px-8 py-4 rounded-full font-semibold hover:bg-emerald-600 hover:text-white transition text-center">
            View Our Services
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Why Choose Hair PRP?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          PRP therapy is a revolutionary treatment that stimulates natural hair growth using your body's own platelets.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center p-6 rounded-2xl bg-emerald-50 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">100% Natural & Safe</h3>
          <p class="text-gray-600">Uses your own blood plasma with no risk of allergic reactions or side effects.</p>
        </div>
        <div class="text-center p-6 rounded-2xl bg-amber-50 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-amber-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">No Downtime</h3>
          <p class="text-gray-600">Return to your daily activities immediately after your 45-minute session.</p>
        </div>
        <div class="text-center p-6 rounded-2xl bg-emerald-50 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Visible Results</h3>
          <p class="text-gray-600">See noticeable improvement in hair thickness and growth within 3-6 months.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">How PRP Treatment Works</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Our simple 3-step process harnesses your body's natural healing abilities.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="relative">
          <div class="text-6xl font-serif font-bold text-emerald-200 absolute -top-4 -left-4">1</div>
          <div class="bg-white p-6 rounded-2xl shadow-md relative z-10">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Blood Collection</h3>
            <p class="text-gray-600">A small amount of blood is drawn from your arm, similar to a routine blood test.</p>
          </div>
        </div>
        <div class="relative">
          <div class="text-6xl font-serif font-bold text-emerald-200 absolute -top-4 -left-4">2</div>
          <div class="bg-white p-6 rounded-2xl shadow-md relative z-10">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">PRP Separation</h3>
            <p class="text-gray-600">The blood is processed in a centrifuge to isolate the platelet-rich plasma.</p>
          </div>
        </div>
        <div class="relative">
          <div class="text-6xl font-serif font-bold text-emerald-200 absolute -top-4 -left-4">3</div>
          <div class="bg-white p-6 rounded-2xl shadow-md relative z-10">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">PRP Injection</h3>
            <p class="text-gray-600">The concentrated PRP is injected into the scalp to stimulate hair follicles.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-emerald-700">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        Ready to Transform Your Hair?
      </h2>
      <p class="text-emerald-100 text-lg mb-8 max-w-2xl mx-auto">
        Schedule a free consultation with our hair restoration specialists in Ajman.
      </p>
      <a href="/contact" class="inline-block bg-amber-500 text-white px-8 py-4 rounded-full font-semibold hover:bg-amber-600 transition shadow-lg">
        Book Your Free Consultation
      </a>
      <p class="text-emerald-200 mt-4 text-sm">Limited slots available - Book today!</p>
    </div>
  </section>
</Layout>
