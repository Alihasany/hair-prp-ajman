---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - Hair PRP Clinic in Ajman">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-emerald-600 to-emerald-800 py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">About Us</h1>
      <p class="text-emerald-100 text-lg max-w-2xl mx-auto">
        Leading the way in non-surgical hair restoration across the UAE.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-6">Our Story</h2>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Founded in 2018, Hair PRP Ajman has become the leading hair restoration clinic in the Northern Emirates.
            Our mission is to provide accessible, effective, and natural hair loss solutions to men and women
            struggling with thinning hair and balding.
          </p>
          <p class="text-gray-600 mb-6 leading-relaxed">
            We specialize exclusively in Platelet-Rich Plasma (PRP) therapy, allowing us to perfect our technique
            and deliver exceptional results. Our team of certified trichologists and medical professionals use
            state-of-the-art technology to ensure every patient receives the highest standard of care.
          </p>
          <div class="grid grid-cols-3 gap-6">
            <div class="text-center">
              <div class="text-4xl font-bold text-emerald-600 mb-2">2000+</div>
              <div class="text-sm text-gray-600">Patients Treated</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-emerald-600 mb-2">95%</div>
              <div class="text-sm text-gray-600">Satisfaction Rate</div>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-emerald-600 mb-2">8+</div>
              <div class="text-sm text-gray-600">Years Experience</div>
            </div>
          </div>
        </div>
        <div class="bg-gradient-to-br from-emerald-100 to-amber-100 rounded-3xl p-8 h-80 flex items-center justify-center">
          <div class="text-center">
            <div class="w-24 h-24 bg-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <p class="text-gray-600 font-medium">Modern Clinic Facility</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Why Choose Hair PRP Ajman?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          We combine expertise, technology, and personalized care for the best results.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-lg transition">
          <div class="w-14 h-14 bg-emerald-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Certified Specialists</h3>
          <p class="text-gray-600 text-sm">Our trichologists are internationally certified with years of experience.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-lg transition">
          <div class="w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Advanced Technology</h3>
          <p class="text-gray-600 text-sm">We use the latest PRP systems for optimal platelet concentration.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-lg transition">
          <div class="w-14 h-14 bg-emerald-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Personalized Care</h3>
          <p class="text-gray-600 text-sm">Customized treatment plans based on your unique hair loss pattern.</p>
        </div>

        <div class="bg-white rounded-2xl p-6 shadow-md hover:shadow-lg transition">
          <div class="w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Transparent Pricing</h3>
          <p class="text-gray-600 text-sm">No hidden fees. Clear packages with flexible payment options.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Team -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Meet Our Team</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          Expert professionals dedicated to your hair restoration success.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-40 h-40 bg-gradient-to-br from-emerald-200 to-emerald-400 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-20 h-20 text-emerald-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900">Dr. Ahmed Al Mansoori</h3>
          <p class="text-emerald-600 font-medium mb-2">Medical Director</p>
          <p class="text-gray-600 text-sm">MBBS, MD Dermatology<br/>15+ years experience</p>
        </div>

        <div class="text-center">
          <div class="w-40 h-40 bg-gradient-to-br from-amber-200 to-amber-400 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-20 h-20 text-amber-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900">Dr. Fatima Hassan</h3>
          <p class="text-amber-600 font-medium mb-2">Lead Trichologist</p>
          <p class="text-gray-600 text-sm">Certified Trichologist<br/>10+ years experience</p>
        </div>

        <div class="text-center">
          <div class="w-40 h-40 bg-gradient-to-br from-emerald-200 to-emerald-400 rounded-full mx-auto mb-4 flex items-center justify-center">
            <svg class="w-20 h-20 text-emerald-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900">Sarah Abdullah</h3>
          <p class="text-emerald-600 font-medium mb-2">Patient Care Manager</p>
          <p class="text-gray-600 text-sm">RN, Aesthetic Certified<br/>8+ years experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Certifications & Memberships</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-8">
        <div class="bg-white rounded-xl p-6 shadow-md text-center min-w-[150px]">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M6 9a2 2 0 00-2 2v3a2 2 0 002 2h3m3-9h3a2 2 0 012 2v3a2 2 0 01-2 2h-3m-6 0H6"/>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-900">DHA Licensed</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md text-center min-w-[150px]">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M6 9a2 2 0 00-2 2v3a2 2 0 002 2h3m3-9h3a2 2 0 012 2v3a2 2 0 01-2 2h-3m-6 0H6"/>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-900">IAT Certified</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md text-center min-w-[150px]">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M6 9a2 2 0 00-2 2v3a2 2 0 002 2h3m3-9h3a2 2 0 012 2v3a2 2 0 01-2 2h-3m-6 0H6"/>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-900">ISO 9001:2015</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-md text-center min-w-[150px]">
          <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M6 9a2 2 0 00-2 2v3a2 2 0 002 2h3m3-9h3a2 2 0 012 2v3a2 2 0 01-2 2h-3m-6 0H6"/>
            </svg>
          </div>
          <p class="text-sm font-semibold text-gray-900">UAE MOH Approved</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-emerald-700">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        Trust Your Hair to the Experts
      </h2>
      <p class="text-emerald-100 text-lg mb-8">
        Schedule a consultation with our specialists today.
      </p>
      <a href="/contact" class="inline-block bg-amber-500 text-white px-8 py-4 rounded-full font-semibold hover:bg-amber-600 transition shadow-lg">
        Book Your Consultation
      </a>
    </div>
  </section>
</Layout>
