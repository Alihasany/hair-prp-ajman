---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Locations - Hair PRP Clinics in Ajman">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-emerald-600 to-emerald-800 py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">Our Locations</h1>
      <p class="text-emerald-100 text-lg max-w-2xl mx-auto">
        Visit our state-of-the-art clinics conveniently located across Ajman, UAE.
      </p>
    </div>
  </section>

  <!-- Main Clinic Location -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <span class="text-emerald-600 font-semibold text-sm uppercase tracking-wider">Flagship Clinic</span>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mt-2 mb-6">Al Nuaimiya Clinic</h2>

          <div class="space-y-6">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center flex-shrink-0 mr-4">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.657 20.657a2 2 0 01-2.828 0l-4-4a2 2 0 010-2.828l8-8a2 2 0 012.828 0M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Address</h3>
                <p class="text-gray-600">Building 12, Street 45<br/>Al Nuaimiya Area<br/>Ajman, United Arab Emirates</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0 mr-4">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Working Hours</h3>
                <p class="text-gray-600">
                  Saturday - Thursday: 9:00 AM - 9:00 PM<br/>
                  Friday: 2:00 PM - 9:00 PM
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center flex-shrink-0 mr-4">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Contact</h3>
                <p class="text-gray-600">
                  Phone: +971 6 123 4567<br/>
                  WhatsApp: +971 50 123 4567<br/>
                  Email: alnuaimiya@hairprpajman.ae
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center flex-shrink-0 mr-4">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 mb-1">Facilities</h3>
                <p class="text-gray-600">
                  Free Parking<br/>
                  Wheelchair Accessible<br/>
                  Private Treatment Rooms
                </p>
              </div>
            </div>
          </div>

          <div class="mt-8 flex gap-4">
            <a href="/contact" class="bg-emerald-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-emerald-700 transition">
              Book Appointment
            </a>
            <a href="tel:+97161234567" class="border-2 border-emerald-600 text-emerald-600 px-6 py-3 rounded-full font-semibold hover:bg-emerald-600 hover:text-white transition">
              Call Now
            </a>
          </div>
        </div>

        <!-- Map Placeholder -->
        <div class="bg-gray-200 rounded-2xl overflow-hidden h-96 lg:h-auto relative">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3619.698996022609!2d55.5136!3d25.4052!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3e5f5c3c3c3c3c3c%3A0x3c3c3c3c3c3c3c3c!2sAl%20Nuaimiya%2C%20Ajman!5e0!3m2!1sen!2sae!4v1234567890"
            width="100%"
            height="100%"
            style="border:0; position: absolute; inset: 0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Second Location -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="bg-gray-300 rounded-2xl overflow-hidden h-80 relative">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3620.0!2d55.4900!3d25.3900!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sAl%20Rawda%2C%20Ajman!5e0!3m2!1sen!2sae!4v1234567890"
              width="100%"
              height="100%"
              style="border:0; position: absolute; inset: 0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <span class="text-emerald-600 font-semibold text-sm uppercase tracking-wider">Coming Soon</span>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mt-2 mb-6">Al Rawda Clinic</h2>

          <p class="text-gray-600 mb-6 leading-relaxed">
            We're expanding! Our second location in Al Rawda will open in Q2 2026, bringing our expert
            Hair PRP treatments to more residents of Ajman.
          </p>

          <div class="space-y-4">
            <div class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Same expert team and advanced technology
            </div>
            <div class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Extended weekend hours
            </div>
            <div class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Free valet parking
            </div>
          </div>

          <div class="mt-8">
            <a href="/contact" class="bg-amber-500 text-white px-6 py-3 rounded-full font-semibold hover:bg-amber-600 transition inline-block">
              Get Notified When We Open
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Areas We Serve</h2>
        <p class="text-gray-600">We welcome patients from all across the UAE.</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <div class="bg-emerald-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Ajman</p>
        </div>
        <div class="bg-amber-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Sharjah</p>
        </div>
        <div class="bg-emerald-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Dubai</p>
        </div>
        <div class="bg-amber-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Umm Al Quwain</p>
        </div>
        <div class="bg-emerald-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Ras Al Khaimah</p>
        </div>
        <div class="bg-amber-50 rounded-xl p-4 text-center hover:shadow-md transition">
          <p class="font-semibold text-gray-900">Fujairah</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-emerald-700">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        Visit Our Clinic Today
      </h2>
      <p class="text-emerald-100 text-lg mb-8">
        Walk-ins welcome, but appointments are recommended for shorter wait times.
      </p>
      <a href="/contact" class="inline-block bg-amber-500 text-white px-8 py-4 rounded-full font-semibold hover:bg-amber-600 transition shadow-lg">
        Book Your Appointment
      </a>
    </div>
  </section>
</Layout>
