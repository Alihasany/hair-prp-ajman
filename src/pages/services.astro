---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services - Hair PRP Treatments in Ajman">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-emerald-600 to-emerald-800 py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4">Our Services</h1>
      <p class="text-emerald-100 text-lg max-w-2xl mx-auto">
        Comprehensive hair restoration solutions tailored to your needs.
      </p>
    </div>
  </section>

  <!-- Main PRP Treatment -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <span class="text-emerald-600 font-semibold text-sm uppercase tracking-wider">Flagship Treatment</span>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mt-2 mb-4">Hair PRP Therapy</h2>
          <p class="text-gray-600 mb-4 leading-relaxed">
            Our signature Platelet-Rich Plasma treatment is a non-surgical procedure that stimulates natural hair growth.
            By injecting concentrated platelets from your own blood into the scalp, we activate dormant hair follicles
            and promote thicker, healthier hair growth.
          </p>
          <ul class="space-y-3 mb-6">
            <li class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Stimulates natural hair growth
            </li>
            <li class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Increases hair thickness and density
            </li>
            <li class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Minimally invasive with no downtime
            </li>
            <li class="flex items-center text-gray-700">
              <svg class="w-5 h-5 text-emerald-500 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              Suitable for men and women
            </li>
          </ul>
          <div class="flex items-center gap-4">
            <span class="text-2xl font-bold text-emerald-600">AED 800</span>
            <span class="text-gray-500">per session</span>
          </div>
        </div>
        <div class="bg-gradient-to-br from-emerald-100 to-amber-100 rounded-3xl p-8 h-80 flex items-center justify-center">
          <div class="text-center">
            <div class="w-24 h-24 bg-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <p class="text-gray-600 font-medium">Advanced PRP Technology</p>
          </div>
        </div>
      </div>

      <!-- Recommended Package -->
      <div class="bg-amber-50 rounded-2xl p-6 text-center mb-12">
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Recommended Package: 4 Sessions</h3>
        <p class="text-gray-600 mb-4">Best results achieved with monthly sessions</p>
        <div class="flex items-center justify-center gap-4">
          <span class="text-gray-400 line-through text-lg">AED 3,200</span>
          <span class="text-3xl font-bold text-amber-600">AED 2,800</span>
          <span class="bg-amber-600 text-white px-3 py-1 rounded-full text-sm font-semibold">Save AED 400</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Services -->
  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-gray-900 mb-4">Additional Services</h2>
        <p class="text-gray-600">Complementary treatments to enhance your hair restoration journey.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Service Card 1 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Hair Loss Consultation</h3>
            <p class="text-gray-600 mb-4">Comprehensive scalp analysis and personalized treatment planning with our specialists.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">AED 200</span>
              <span class="text-sm text-gray-500">45 min</span>
            </div>
          </div>
        </div>

        <!-- Service Card 2 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Scalp Micropigmentation</h3>
            <p class="text-gray-600 mb-4">Cosmetic tattooing that creates the appearance of fuller hair and covers thinning areas.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">AED 1,500</span>
              <span class="text-sm text-gray-500">per session</span>
            </div>
          </div>
        </div>

        <!-- Service Card 3 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Maintenance Therapy</h3>
            <p class="text-gray-600 mb-4">Quarterly PRP sessions to maintain and enhance your hair growth results.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">AED 600</span>
              <span class="text-sm text-gray-500">per session</span>
            </div>
          </div>
        </div>

        <!-- Service Card 4 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">PRP + Mesotherapy</h3>
            <p class="text-gray-600 mb-4">Combined treatment with vitamin-rich cocktails for enhanced hair nourishment.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">AED 1,200</span>
              <span class="text-sm text-gray-500">per session</span>
            </div>
          </div>
        </div>

        <!-- Service Card 5 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Beard PRP Treatment</h3>
            <p class="text-gray-600 mb-4">Stimulate beard growth and fill in patchy areas with targeted PRP therapy.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">AED 600</span>
              <span class="text-sm text-gray-500">per session</span>
            </div>
          </div>
        </div>

        <!-- Service Card 6 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition">
          <div class="h-48 bg-gradient-to-br from-amber-500 to-amber-700 flex items-center justify-center">
            <svg class="w-16 h-16 text-white opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Follow-Up Consultation</h3>
            <p class="text-gray-600 mb-4">Progress tracking and treatment adjustment sessions for existing patients.</p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-emerald-600">Free</span>
              <span class="text-sm text-gray-500">30 min</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-emerald-700">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-white mb-4">
        Start Your Hair Restoration Journey Today
      </h2>
      <p class="text-emerald-100 text-lg mb-8">
        Book a consultation to discuss the best treatment plan for your needs.
      </p>
      <a href="/contact" class="inline-block bg-amber-500 text-white px-8 py-4 rounded-full font-semibold hover:bg-amber-600 transition shadow-lg">
        Book Your Appointment
      </a>
    </div>
  </section>
</Layout>
