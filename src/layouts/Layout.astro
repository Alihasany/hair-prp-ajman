---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Expert Hair PRP Treatment in Ajman, UAE. Restore your hair naturally with our advanced platelet-rich plasma therapy." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Hair PRP, Ajman, UAE, Hair Loss Treatment, Platelet Rich Plasma, Hair Restoration" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Hair PRP Ajman</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="font-sans">
    <header class="bg-white shadow-md sticky top-0 z-50">
      <nav class="container mx-auto px-4 py-4">
        <div class="flex justify-between items-center">
          <a href="/" class="text-2xl font-serif font-bold text-emerald-700">
            Hair PRP<span class="text-amber-600">Ajman</span>
          </a>

          <!-- Desktop Menu -->
          <ul class="hidden md:flex space-x-8">
            <li><a href="/" class="text-gray-700 hover:text-emerald-600 transition font-medium">Home</a></li>
            <li><a href="/services" class="text-gray-700 hover:text-emerald-600 transition font-medium">Services</a></li>
            <li><a href="/locations" class="text-gray-700 hover:text-emerald-600 transition font-medium">Locations</a></li>
            <li><a href="/about" class="text-gray-700 hover:text-emerald-600 transition font-medium">About</a></li>
            <li><a href="/contact" class="bg-emerald-600 text-white px-5 py-2 rounded-full hover:bg-emerald-700 transition font-medium">Contact</a></li>
          </ul>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden text-gray-700 focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <ul id="mobile-menu" class="hidden md:hidden flex-col space-y-4 mt-4 pb-4">
          <li><a href="/" class="text-gray-700 hover:text-emerald-600 transition font-medium block">Home</a></li>
          <li><a href="/services" class="text-gray-700 hover:text-emerald-600 transition font-medium block">Services</a></li>
          <li><a href="/locations" class="text-gray-700 hover:text-emerald-600 transition font-medium block">Locations</a></li>
          <li><a href="/about" class="text-gray-700 hover:text-emerald-600 transition font-medium block">About</a></li>
          <li><a href="/contact" class="bg-emerald-600 text-white px-5 py-2 rounded-full hover:bg-emerald-700 transition font-medium block text-center">Contact</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-gray-900 text-white py-12">
      <div class="container mx-auto px-4">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <h3 class="text-xl font-serif font-bold text-emerald-400 mb-4">Hair PRP Ajman</h3>
            <p class="text-gray-400 text-sm">Expert hair restoration treatments using advanced PRP therapy in Ajman, UAE.</p>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Quick Links</h4>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li><a href="/" class="hover:text-emerald-400 transition">Home</a></li>
              <li><a href="/services" class="hover:text-emerald-400 transition">Services</a></li>
              <li><a href="/about" class="hover:text-emerald-400 transition">About</a></li>
              <li><a href="/contact" class="hover:text-emerald-400 transition">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Services</h4>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li>Hair PRP Treatment</li>
              <li>Hair Loss Consultation</li>
              <li>Scalp Micropigmentation</li>
              <li>Maintenance Therapy</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-4">Contact</h4>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li>Al Nuaimiya, Ajman, UAE</li>
              <li>+971 6 123 4567</li>
              <li>info@hairprpajman.ae</li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400 text-sm">
          <p>&copy; {new Date().getFullYear()} Hair PRP Ajman. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  .font-serif {
    font-family: 'Playfair Display', serif;
  }

  .font-sans {
    font-family: 'Inter', sans-serif;
  }
</style>
